# Copie para .env.production na VPS e preencha. NÃO commitar.
# Postgres
POSTGRES_USER=openboard
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=openboard

# Segredo de sessão — OBRIGATÓRIO, mínimo 32 caracteres (o app falha-fechado sem isso).
# Gere com: openssl rand -base64 48
AUTH_SECRET=

# Chave AES p/ criptografar o access token do Instagram em repouso (32 bytes base64).
# Gere com: openssl rand -base64 32. Necessária p/ conectar/renovar token do IG.
TOKEN_ENC_KEY=

# Porta local onde o app escuta (o nginx faz proxy de /openboard pra cá).
APP_PORT=3001

# Cookie de sessão Secure: deixe false em HTTP (IP sem TLS). true só com HTTPS.
COOKIE_SECURE=false

# Painel de TV (kiosk) em /tv?key=TV_TOKEN. Gere com: openssl rand -hex 24
# Sem valor, o /tv fica inacessível. TV_WORKSPACE_ID é opcional (default = 1º workspace).
TV_TOKEN=
TV_WORKSPACE_ID=

# ── Comercial / Integração IXCSoft (server-only) ────────────────────────────
# Ver IXC_INTEGRATION_HANDOFF.md. Token NUNCA no bundle (sem NEXT_PUBLIC).
IXC_BASE_URL=https://central.openitgroup.com.br
IXC_PROXY_URL=http://104.234.186.129:3001
IXC_TOKEN=
IXC_FILIAIS=1,2,6
# IXC_CAMPO_STATUS_CONTRATO=status

# ── Leads ────────────────────────────────────────────────────────────────────
# Token do webhook de ingest de leads (chat de atendimento -> POST /api/comercial/leads).
# Gere com: openssl rand -hex 24. Sem valor, o webhook rejeita tudo (401).
LEADS_INGEST_TOKEN=

# ── Domínio / HTTPS ──────────────────────────────────────────────────────────
# Base pública do app (links de reset de senha). Com domínio: https://crm.opensuite.com.br
# (acrescente /openboard no fim SE o build mantiver o basePath).
APP_URL=

# ── Marketing / Links & QR (encurtador) ──────────────────────────────────────
# Base da URL curta impressa no QR. Ex.: https://crm.opensuite.com.br
# (com /openboard no fim SE o build mantiver o basePath). É isso que vai pro papel.
SHORT_BASE_URL=
# Sal do hash de IP dos cliques (LGPD — IP puro nunca é gravado). openssl rand -hex 16
SHORT_IP_SALT=
