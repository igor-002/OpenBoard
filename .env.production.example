# Copie para .env.production na VPS e preencha. NÃO commitar.
# Postgres
POSTGRES_USER=openboard
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=openboard

# Segredo de sessão — OBRIGATÓRIO, mínimo 32 caracteres (o app falha-fechado sem isso).
# Gere com: openssl rand -base64 48
AUTH_SECRET=

# Chave AES p/ criptografar o access token do Instagram em repouso (32 bytes base64).
# Gere com: openssl rand -base64 32. Necessária p/ conectar/renovar token do IG.
TOKEN_ENC_KEY=

# Porta local onde o app escuta (o nginx do domínio faz proxy da raiz pra cá).
APP_PORT=3001

# Cookie de sessão Secure: true com HTTPS (domínio). Só deixe false em HTTP puro.
COOKIE_SECURE=true

# Painel de TV (kiosk) em /tv?key=TV_TOKEN. Gere com: openssl rand -hex 24
# Sem valor, o /tv fica inacessível. TV_WORKSPACE_ID é opcional (default = 1º workspace).
TV_TOKEN=
TV_WORKSPACE_ID=

# ── Comercial / Integração IXCSoft (server-only) ────────────────────────────
# Ver IXC_INTEGRATION_HANDOFF.md. Token NUNCA no bundle (sem NEXT_PUBLIC).
IXC_BASE_URL=https://central.openitgroup.com.br
IXC_PROXY_URL=http://104.234.186.129:3001
IXC_TOKEN=
IXC_FILIAIS=1,2,6
# IXC_CAMPO_STATUS_CONTRATO=status

# ── Marketing / Integração GLPI (server-only) ───────────────────────────────
# Espelho read-only dos chamados do GLPI 11 (API V2.1 / OAuth2). Segredos NUNCA no
# bundle (sem NEXT_PUBLIC). Ver glpi-api-v2-integracao.md. Sem essas vars a aba
# "Demandas (GLPI)" fica "não configurado" e o scheduler desliga.
GLPI_URL=https://chamados.openitcorp.com.br
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=
GLPI_USERNAME=integracaomkt
GLPI_PASSWORD=
# IDs (não logins) dos usuários do GLPI cujos chamados contam como demanda do mkt.
GLPI_TRACKED_USER_IDS=40,41,43,60
# GLPI_SYNC_INTERVAL_MIN=30

# ── Leads ────────────────────────────────────────────────────────────────────
# Token do webhook de ingest de leads (chat de atendimento -> POST /api/comercial/leads).
# Gere com: openssl rand -hex 24. Sem valor, o webhook rejeita tudo (401).
LEADS_INGEST_TOKEN=

# ── Domínio / HTTPS ──────────────────────────────────────────────────────────
# Base pública do app (links de reset de senha). Ex.: https://crm.opensuite.com.br
# (o build serve na raiz — BASE_PATH vazio no Dockerfile; sem /openboard).
APP_URL=

# ── Marketing / Links & QR (encurtador) ──────────────────────────────────────
# Base da URL curta impressa no QR. Ex.: https://crm.opensuite.com.br
# (raiz, sem /openboard — o QR vira https://.../r/xxx). É isso que vai pro papel.
SHORT_BASE_URL=
# Sal do hash de IP dos cliques (LGPD — IP puro nunca é gravado). openssl rand -hex 16
SHORT_IP_SALT=
# Geolocalização local MaxMind GeoLite2 (sem limite; fallback é ip-api.com ~45/min).
# Conta gratuita em maxmind.com → Manage License Keys. Baixar: npm run geoip:update
# Atualizar semanal via cron (o app recarrega o arquivo sozinho, sem restart).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# GEOIP_DB_PATH=geoip/GeoLite2-City.mmdb
