// OpenBoard — schema do banco. Derivado de data.jsx do protótipo.
generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" = ambiente local; debian-openssl-3.0.x = imagem Docker de produção (bookworm-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  gerente
  membro
}

enum ProjectStatus {
  progress
  done
  review
  planned
}

enum Priority {
  high
  med
  low
}

enum TaskColumn {
  todo
  doing
  review
  done
}

enum TimeLogStatus {
  running
  paused
  done
}

enum MilestoneState {
  done
  doing
  todo
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  users     User[]
  projects  Project[]
}

model User {
  id           String   @id @default(cuid())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId  String
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(membro)
  jobTitle     String
  initials     String
  color        String
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())

  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  timeLogs       TimeLog[]
  notes          ProjectNote[]
  notifications  Notification[]
  taskComments   TaskComment[]

  @@index([workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  name        String
  client      String
  tag         String
  status      ProjectStatus @default(planned)
  progress    Int           @default(0)
  startDate   DateTime
  dueDate     DateTime?
  budgetCents Int           @default(0)
  spentPct    Int           @default(0)
  risk        Boolean       @default(false)
  createdAt   DateTime      @default(now())

  members    ProjectMember[]
  tasks      Task[]
  milestones Milestone[]
  timeLogs   TimeLog[]
  notes      ProjectNote[]

  @@index([workspaceId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String // task_assigned | note_added | project_member
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model ProjectNote {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

model ProjectMember {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  isLead    Boolean @default(false)
  order     Int     @default(0)

  @@id([projectId, userId])
  @@index([userId])
}

model Task {
  id         String     @id @default(cuid())
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  title      String
  column     TaskColumn @default(todo)
  priority   Priority   @default(med)
  dueDate    DateTime?
  assignee   User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId String?
  order      Int        @default(0)
  createdAt  DateTime   @default(now())

  tags     TaskTag[]
  subtasks Subtask[]
  comments TaskComment[]

  @@index([projectId])
  @@index([assigneeId])
}

model Subtask {
  id     String  @id @default(cuid())
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  title  String
  done   Boolean @default(false)
  order  Int     @default(0)

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorId])
}

model TaskTag {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  label  String

  @@index([taskId])
}

model Milestone {
  id        String         @id @default(cuid())
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  state     MilestoneState @default(todo)
  date      DateTime
  order     Int            @default(0)

  @@index([projectId])
}

model TimeLog {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  taskTitle   String
  durationSec Int           @default(0)
  startedAt   DateTime
  status      TimeLogStatus @default(running)

  @@index([userId])
  @@index([projectId])
}
