// OpenBoard — schema do banco. Derivado de data.jsx do protótipo.
generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" = ambiente local; debian-openssl-3.0.x = imagem Docker de produção (bookworm-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  gerente
  membro
}

enum ProjectStatus {
  progress
  done
  review
  planned
}

enum Priority {
  high
  med
  low
}

enum TaskColumn {
  todo
  doing
  review
  done
}

enum TimeLogStatus {
  running
  paused
  done
}

enum MilestoneState {
  done
  doing
  todo
}

// Origem da tarefa/atividade: planejada (atribuída de cima), avulsa (registrada
// pelo próprio membro) ou presencial (solicitação na porta da sala). Base dos
// relatórios de volume de demanda.
enum TaskOrigin {
  planejada
  avulsa
  presencial
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  users     User[]
  projects  Project[]
  tasks     Task[]
}

model User {
  id           String   @id @default(cuid())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId  String
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(membro)
  jobTitle     String
  initials     String
  color        String
  hourlyCostCents Int   @default(0) // custo/hora p/ margem real (D1)
  // Controle de acesso por módulo. Admin ignora (vê tudo). Para gerente/membro,
  // só entra nos módulos listados aqui. Chaves válidas: gestao, comercial, leads,
  // margem, marketing (ver src/lib/permissions.ts). Vazio = sem acesso a módulos gated.
  modules      String[] @default([])
  mustChangePassword Boolean @default(false)
  // "Esqueci minha senha": guarda só o SHA-256 do token (nunca o token cru).
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  createdAt    DateTime @default(now())

  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  timeLogs       TimeLog[]
  notes          ProjectNote[]
  notifications  Notification[]
  taskComments   TaskComment[]
  createdProjects Project[]      @relation("ProjectCreator")

  @@index([workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  name        String
  client      String
  tag         String
  status      ProjectStatus @default(planned)
  manualProgress Int?       // override manual; null = progresso automático (% tarefas concluídas)
  startDate   DateTime
  dueDate     DateTime?
  budgetCents Int           @default(0)
  spentPct    Int           @default(0)
  risk        Boolean       @default(false)
  ixcClienteId String?      // vínculo frouxo ao IxcCliente (A2 — Cliente 360), sem FK
  createdAt   DateTime      @default(now())
  creator     User?         @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId   String?

  members    ProjectMember[]
  tasks      Task[]
  milestones Milestone[]
  timeLogs   TimeLog[]
  notes      ProjectNote[]

  @@index([workspaceId])
  @@index([creatorId])
  @@index([ixcClienteId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String // task_assigned | note_added | project_member
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model ProjectNote {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

model ProjectMember {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  isLead    Boolean @default(false)
  order     Int     @default(0)

  @@id([projectId, userId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  // workspaceId direto: permite tarefa SEM projeto (atividade avulsa/presencial).
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String?
  title       String
  column      TaskColumn @default(todo)
  priority    Priority   @default(med)
  dueDate     DateTime?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  doneAt      DateTime?  // quando entrou na coluna "done" (métricas de entrega)

  // ── Atividades da Equipe ──
  origem           TaskOrigin  @default(planejada)
  tipo             TaskType?   @relation(fields: [tipoId], references: [id], onDelete: SetNull)
  tipoId           String?
  // FK real pelo cuid do IxcCliente (≠ Project.ixcClienteId, que é loose ref
  // pelo ixcId do IXC) — clientes manuais não têm ixcId.
  ixcCliente       IxcCliente? @relation(fields: [ixcClienteId], references: [id], onDelete: SetNull)
  ixcClienteId     String?
  startedAt        DateTime?   // 1ª entrada em "doing" (duração real = doneAt − startedAt)
  estimatedMinutes Int?
  report           String?     // relato final de execução (ao concluir)

  tags     TaskTag[]
  subtasks Subtask[]
  comments TaskComment[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([tipoId])
  @@index([ixcClienteId])
}

// Tipo/categoria de atividade (Suporte, Instalação, …). Extensível — seed
// inicial via migration; admin pode adicionar depois.
model TaskType {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  active Boolean @default(true)
  order  Int     @default(0)
  tasks  Task[]
}

model Subtask {
  id     String  @id @default(cuid())
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  title  String
  done   Boolean @default(false)
  order  Int     @default(0)

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorId])
}

model TaskTag {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  label  String

  @@index([taskId])
}

model Milestone {
  id        String         @id @default(cuid())
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  state     MilestoneState @default(todo)
  date      DateTime
  order     Int            @default(0)

  @@index([projectId])
}

model TimeLog {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  taskTitle   String
  durationSec Int           @default(0)
  startedAt   DateTime
  status      TimeLogStatus @default(running)

  @@index([userId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMERCIAL — espelho local da integração IXCSoft (segundo "sistema").
// Dados puxados do IXC via sync (ver src/server/comercial/sync.ts). São globais
// da empresa (single-tenant), por isso NÃO vinculam a Workspace. Vínculos com o
// OpenBoard (ex.: Vendedor ↔ User) ficam frouxos por id, sem FK, pra não acoplar
// a ordem de sync. Status do contrato é String (códigos IXC: A/AA/P/B/C/FA/N…),
// configurável por versão — não vira enum.
// ─────────────────────────────────────────────────────────────────────────────

// Vendedor do IXC. Pode mapear pra um User local (campo userId) pra cruzar com o
// OpenBoard depois.
model Vendedor {
  id        String   @id @default(cuid())
  ixcId     String   @unique // id_vendedor no IXC
  nome      String
  status    String   @default("A") // 'A' = ativo (status no IXC)
  // Governança local (toggles na tela Vendedores — preservados entre syncs):
  ativo            Boolean @default(false) // "Ativo no CRM": aparece nas listas/telas
  incluirHistorico Boolean @default(false) // gate do sync: só estes têm contratos puxados do IXC
  userId    String? // User local vinculado (opcional, sem FK)
  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
}

// Cliente do IXC (tabela `cliente`) OU cliente manual criado em /atividades
// (manual=true, ixcId=null — fica fora do sync e das telas comerciais).
model IxcCliente {
  id       String   @id @default(cuid())
  ixcId    String?  @unique // cliente.id no IXC; null = cliente manual
  manual   Boolean  @default(false)
  razao    String
  cnpjCpf  String?
  uf       String?
  syncedAt DateTime @default(now())
  tasks    Task[]
}

// Contrato do IXC (`cliente_contrato`) com MRR já calculado no sync (ver handoff).
model Contrato {
  id                  String   @id @default(cuid())
  ixcId               String   @unique // cliente_contrato.id
  status              String   @default("A") // código IXC
  filial              String? // id_filial
  mrrCents            Int      @default(0) // MRR limpo calculado no sync
  taxaInstalacaoCents Int      @default(0)
  idVdContrato        String? // id do plano (vínculo "Plano")
  dataAtivacao        DateTime?
  dataCadastro        DateTime?
  syncedAt            DateTime @default(now())

  // Vínculos frouxos por ixcId (SEM FK) — IXC manda contratos de vendedores
  // inativos/fora do escopo; FK quebraria o upsert. Join feito nas queries.
  clienteIxcId  String
  vendedorIxcId String?

  @@index([status])
  @@index([vendedorIxcId])
  @@index([clienteIxcId])
}

// Lead do funil comercial (Kanban). Global. Criado manualmente OU via ingest do
// sistema de chat de atendimento (POST /api/comercial/leads). Dedup por
// externalId / cnpjCpfNorm / contatoNorm / emailNorm (ver src/lib/leads.ts).
model Lead {
  id                 String   @id @default(cuid())
  nome               String
  empresa            String?
  cnpjCpf            String?  // como recebido (formatado)
  cnpjCpfNorm        String?  // só dígitos (11/14) — chave de dedup
  contato            String?  // telefone/whatsapp como recebido
  contatoNorm        String?  // últimos 11 dígitos — chave de dedup
  email              String?
  emailNorm          String?  // minúsculo — chave de dedup
  origem             String?  // ex.: "chat-atendimento"
  externalId         String?  @unique // id do lead no sistema externo — dedup forte
  valorEstimadoCents Int      @default(0)
  observacoes        String?
  stage              String   @default("contato") // ver LEAD_STAGES (funil de 4 estágios)
  stageChangedAt     DateTime @default(now()) // quando entrou no estágio atual (tempo em fila)
  order              Int      @default(0)
  ixcClienteId       String?  // casado a um cliente IXC (por doc), se houver
  assignedUserId     String?  // responsável OpenBoard
  payload            Json?    // payload bruto do ingest (auditoria)
  eventoUltimo       String?  // último evento do AtendAI (ex.: ENTRADA_NOVA_CONVERSA_FILA)
  finalizadoAt       DateTime? // setado quando chega evento de finalização do atendimento
  lastContactAt      DateTime @default(now()) // último toque (ingest re-bate aqui)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Análise IA da conversa do atendente (sob demanda; re-executável, sobrescreve).
  analiseNota           Int?      // 0-10
  analiseResumo         String?
  analisePontos         Json?     // { fortes:[], aMelhorar:[], proximoPasso:"" }
  analiseModelo         String?
  analiseTokensIn       Int?
  analiseTokensOut      Int?
  analiseCustoUsdMicros Int?      // custo em USD * 1_000_000 (inteiro)
  analiseAt             DateTime?

  @@index([stage])
  @@index([cnpjCpfNorm])
  @@index([contatoNorm])
  @@index([emailNorm])
}

// Configurações do app editáveis pela UI (key-value). Ex.: chave/modelo/preço da
// OpenAI. Server-only (nunca expor valores sensíveis ao client). Fallback = env.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Mensagens da conversa do AtendAI, por lead. Acumulam entre re-entradas de fila;
// dedup por externalId (id da mensagem no AtendAI). Ver src/server/comercial/leads.ts.
model LeadMensagem {
  id          String    @id @default(cuid())
  leadId      String    // loose FK -> Lead.id (sem constraint, padrão do comercial)
  externalId  String    @unique // mensagensAtendimento[].id no AtendAI
  remetente   String?   // "OpenSuite" / nome do atendente / cliente
  mensagem    String
  tipo        String?   // tipo_mensagem (text/...)
  mensagemBot Boolean   @default(false) // mensagem_bot || mensagem_ia
  sentAt      DateTime? // data_envio
  createdAt   DateTime  @default(now())

  @@index([leadId])
}

// Histórico de transições de estágio do lead (base dos relatórios de tempo em fila).
// fromStage null = entrada do lead no funil (criação).
model LeadStageEvent {
  id            String   @id @default(cuid())
  leadId        String   // loose FK -> Lead.id (sem constraint, padrão do comercial)
  fromStage     String?
  toStage       String
  movedByUserId String?  // quem moveu (null = sistema/webhook)
  createdAt     DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([toStage, createdAt])
}

// Transição de status de contrato detectada no sync (upsert viu status diferente
// do espelho local). Base do relatório de churn/net-MRR — o IXC não expõe esse
// histórico, então ele acumula daqui pra frente. Vínculos frouxos (padrão comercial).
model ContratoStatusEvent {
  id            String   @id @default(cuid())
  contratoIxcId String
  clienteIxcId  String
  vendedorIxcId String?
  fromStatus    String
  toStatus      String
  mrrCents      Int      @default(0) // MRR do contrato no momento da transição
  createdAt     DateTime @default(now())

  @@index([contratoIxcId])
  @@index([toStatus, createdAt])
  @@index([createdAt])
}

// Log de cada execução de sync (observabilidade — ver handoff §9).
model SyncRun {
  id         String    @id @default(cuid())
  kind       String // "full" | "vendedores" | "contratos" | "reconcile"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  durationMs Int?
  processed  Int       @default(0)
  errors     Int       @default(0)
  fatalError String?

  @@index([kind, startedAt])
}

// Meta do time por mês (replica SalesTracker §4). Global.
model Meta {
  id            String   @id @default(cuid())
  mes           Int
  ano           Int
  metaContratos Int      @default(0) // meta de contratos ativos no mês
  metaMrrCents  Int      @default(0) // meta de MRR no mês (opcional)
  metaSemanal   Int      @default(0) // meta semanal de contratos (opcional)
  createdAt     DateTime @default(now())

  @@unique([mes, ano])
}

// Meta por vendedor por mês (vínculo frouxo por vendedorIxcId, sem FK).
model MetaVendedor {
  id            String   @id @default(cuid())
  vendedorIxcId String
  mes           Int
  ano           Int
  metaContratos Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([vendedorIxcId, mes, ano])
  @@index([mes, ano])
}

// Apontamento diário manual de esforço comercial (replica SalesTracker §6).
// 1 linha por vendedor+dia. NÃO vem do IXC — preenchido na tela.
model RelatorioDiario {
  id            String   @id @default(cuid())
  vendedorIxcId String
  data          DateTime // dia (00:00 UTC)
  leads         Int      @default(0)
  contatos      Int      @default(0)
  callsReunioes Int      @default(0)
  vendas        Int      @default(0)
  valorCents    Int      @default(0)
  produtos      Json?    // [{ nome: string, valorCents: number }] — vendas do dia
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([vendedorIxcId, data])
  @@index([data])
}

// ─────────────────────────────────────────────────────────────────────────────
// MARKETING — portado de github.com/igor-002/openmarketing
// (ver docs/HANDOFF-OPENBOARD.md). Duas áreas independentes:
//  - Redes Sociais: métricas mensais de contas Instagram agrupadas por empresa,
//    coletadas via job de sync (Instagram Graph API).
//  - Gestão da Equipe: produção por funcionário via tarefas (CRUD manual hoje;
//    GLPI é integração futura — Task.source distingue a origem).
// Sem RBAC — qualquer usuário logado vê e edita tudo (igual ao app de origem).
// ─────────────────────────────────────────────────────────────────────────────

model MarketingCompany {
  id       String             @id @default(cuid())
  name     String
  slug     String             @unique // "todas" é reservado p/ visão agregada — não usar em empresa real
  accounts InstagramAccount[]
}

model InstagramAccount {
  id             String                  @id @default(cuid())
  companyId      String
  company        MarketingCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  username       String                  @unique
  displayName    String
  active         Boolean                 @default(true)
  // Credenciais da Instagram API ficam AQUI (não em env): a renovação automática
  // troca o token a cada ciclo (~60 dias). Sem token = conta ainda não conectada,
  // o sync pula.
  igUserId       String?                 @unique
  accessToken    String?
  tokenExpiresAt DateTime?
  lastSyncAt     DateTime?
  accountMetrics AccountMetricsHistory[]
  mediaMetrics   MediaTypeStats[]
}

// Snapshot mensal de métricas por conta. metricName é string livre (inclui
// chaves dinâmicas com prefixo views_follow:* / views_media:* — não virar enum,
// a Meta adiciona categorias).
model AccountMetricsHistory {
  id          String           @id @default(cuid())
  accountId   String
  account     InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metricName  String
  value       Int
  period      String // "YYYY-MM"
  collectedAt DateTime         @default(now())

  @@unique([accountId, metricName, period])
  @@index([period])
}

// Distribuição de tipos de mídia publicada por mês (donut de formatos).
model MediaTypeStats {
  id        String           @id @default(cuid())
  accountId String
  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  mediaType String // IMAGE | VIDEO | CAROUSEL_ALBUM (vocabulário da mídia, diferente do breakdown de views)
  count     Int
  period    String

  @@unique([accountId, mediaType, period])
}

model Employee {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  role        String
  avatarColor String
  // User local vinculado (opcional, sem FK — mesmo padrão de Vendedor.userId).
  userId      String?
  tasks       MarketingTask[]

  @@index([userId])
}

// Nome MarketingTask (não Task) — já existe model Task pro kanban de projetos.
model MarketingTask {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String    @default("")
  status      String    @default("pendente") // pendente | em_andamento | concluida ("atrasada" é derivada, nunca gravada)
  priority    String    @default("media") // baixa | media | alta
  source      String    @default("manual") // manual | glpi (integração futura)
  createdAt   DateTime  @default(now())
  dueDate     DateTime?
  completedAt DateTime?

  @@index([employeeId, status])
}

// ── Encurtador de links + QR + analytics (aba "Links & QR" do Marketing) ─────
// Visibilidade compartilhada do módulo (sem RBAC), igual ao resto do Marketing.
// createdById é vínculo frouxo com User (sem FK), padrão Employee.userId.

model LinkCampaign {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  links     ShortLink[]
}

model ShortLink {
  id          String        @id @default(cuid())
  slug        String        @unique // base62 6-7 chars ou personalizado
  destination String // URL final SEMPRE materializada (o redirect só lê este campo)
  title       String        @default("")
  kind        String        @default("url") // url | whatsapp
  waPhone     String? // só kind=whatsapp (dígitos com DDI)
  waMessage   String? // só kind=whatsapp (texto cru, sem encode)
  tags        String        @default("") // separadas por vírgula
  active      Boolean       @default(true)
  expiresAt   DateTime? // expiração checada on-read no redirect (nunca gravada como status)
  campaignId  String?
  campaign    LinkCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdById String? // User.id frouxo, sem FK
  // Customização do QR persistida (pra re-baixar idêntico depois)
  qrColor     String        @default("#111111")
  qrBgColor   String        @default("#ffffff")
  qrLogo      String?       @db.Text // data URI da logo central (limitado a ~64KB na action)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  clicks      LinkClick[]

  @@index([campaignId])
}

model LinkClick {
  id         Int       @id @default(autoincrement())
  linkId     String
  link       ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  ipHash     String? // sha256(ip + SHORT_IP_SALT) — LGPD: nunca IP puro
  country    String?
  region     String? // estado/UF
  city       String?
  latitude   Float? // centroide da cidade (GeoLite2/ip-api) — pro mapa de pontos
  longitude  Float?
  deviceType String? // mobile | tablet | desktop
  os         String?
  browser    String?
  referrer   String?
  isBot      Boolean   @default(false) // bots de preview (WhatsApp/Telegram) ficam fora dos gráficos

  @@index([linkId, createdAt])
}
