// OpenBoard — schema do banco. Derivado de data.jsx do protótipo.
generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" = ambiente local; debian-openssl-3.0.x = imagem Docker de produção (bookworm-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  gerente
  membro
}

enum ProjectStatus {
  progress
  done
  review
  planned
}

enum Priority {
  high
  med
  low
}

enum TaskColumn {
  todo
  doing
  review
  done
}

enum TimeLogStatus {
  running
  paused
  done
}

enum MilestoneState {
  done
  doing
  todo
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  users     User[]
  projects  Project[]
}

model User {
  id           String   @id @default(cuid())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId  String
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(membro)
  jobTitle     String
  initials     String
  color        String
  hourlyCostCents Int   @default(0) // custo/hora p/ margem real (D1)
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())

  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  timeLogs       TimeLog[]
  notes          ProjectNote[]
  notifications  Notification[]
  taskComments   TaskComment[]
  createdProjects Project[]      @relation("ProjectCreator")

  @@index([workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  name        String
  client      String
  tag         String
  status      ProjectStatus @default(planned)
  manualProgress Int?       // override manual; null = progresso automático (% tarefas concluídas)
  startDate   DateTime
  dueDate     DateTime?
  budgetCents Int           @default(0)
  spentPct    Int           @default(0)
  risk        Boolean       @default(false)
  ixcClienteId String?      // vínculo frouxo ao IxcCliente (A2 — Cliente 360), sem FK
  createdAt   DateTime      @default(now())
  creator     User?         @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId   String?

  members    ProjectMember[]
  tasks      Task[]
  milestones Milestone[]
  timeLogs   TimeLog[]
  notes      ProjectNote[]

  @@index([workspaceId])
  @@index([creatorId])
  @@index([ixcClienteId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String // task_assigned | note_added | project_member
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model ProjectNote {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

model ProjectMember {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  isLead    Boolean @default(false)
  order     Int     @default(0)

  @@id([projectId, userId])
  @@index([userId])
}

model Task {
  id         String     @id @default(cuid())
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  title      String
  column     TaskColumn @default(todo)
  priority   Priority   @default(med)
  dueDate    DateTime?
  assignee   User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId String?
  order      Int        @default(0)
  createdAt  DateTime   @default(now())

  tags     TaskTag[]
  subtasks Subtask[]
  comments TaskComment[]

  @@index([projectId])
  @@index([assigneeId])
}

model Subtask {
  id     String  @id @default(cuid())
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  title  String
  done   Boolean @default(false)
  order  Int     @default(0)

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorId])
}

model TaskTag {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  label  String

  @@index([taskId])
}

model Milestone {
  id        String         @id @default(cuid())
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  state     MilestoneState @default(todo)
  date      DateTime
  order     Int            @default(0)

  @@index([projectId])
}

model TimeLog {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  taskTitle   String
  durationSec Int           @default(0)
  startedAt   DateTime
  status      TimeLogStatus @default(running)

  @@index([userId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMERCIAL — espelho local da integração IXCSoft (segundo "sistema").
// Dados puxados do IXC via sync (ver src/server/comercial/sync.ts). São globais
// da empresa (single-tenant), por isso NÃO vinculam a Workspace. Vínculos com o
// OpenBoard (ex.: Vendedor ↔ User) ficam frouxos por id, sem FK, pra não acoplar
// a ordem de sync. Status do contrato é String (códigos IXC: A/AA/P/B/C/FA/N…),
// configurável por versão — não vira enum.
// ─────────────────────────────────────────────────────────────────────────────

// Vendedor do IXC. Pode mapear pra um User local (campo userId) pra cruzar com o
// OpenBoard depois.
model Vendedor {
  id        String   @id @default(cuid())
  ixcId     String   @unique // id_vendedor no IXC
  nome      String
  status    String   @default("A") // 'A' = ativo (status no IXC)
  // Governança local (toggles na tela Vendedores — preservados entre syncs):
  ativo            Boolean @default(false) // "Ativo no CRM": aparece nas listas/telas
  incluirHistorico Boolean @default(false) // gate do sync: só estes têm contratos puxados do IXC
  userId    String? // User local vinculado (opcional, sem FK)
  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
}

// Cliente do IXC (tabela `cliente`).
model IxcCliente {
  id       String   @id @default(cuid())
  ixcId    String   @unique // cliente.id
  razao    String
  cnpjCpf  String?
  uf       String?
  syncedAt DateTime @default(now())
}

// Contrato do IXC (`cliente_contrato`) com MRR já calculado no sync (ver handoff).
model Contrato {
  id                  String   @id @default(cuid())
  ixcId               String   @unique // cliente_contrato.id
  status              String   @default("A") // código IXC
  filial              String? // id_filial
  mrrCents            Int      @default(0) // MRR limpo calculado no sync
  taxaInstalacaoCents Int      @default(0)
  idVdContrato        String? // id do plano (vínculo "Plano")
  dataAtivacao        DateTime?
  dataCadastro        DateTime?
  syncedAt            DateTime @default(now())

  // Vínculos frouxos por ixcId (SEM FK) — IXC manda contratos de vendedores
  // inativos/fora do escopo; FK quebraria o upsert. Join feito nas queries.
  clienteIxcId  String
  vendedorIxcId String?

  @@index([status])
  @@index([vendedorIxcId])
  @@index([clienteIxcId])
}

// Lead do funil comercial (Kanban). Global. Criado manualmente OU via ingest do
// sistema de chat de atendimento (POST /api/comercial/leads). Dedup por
// externalId / cnpjCpfNorm / contatoNorm / emailNorm (ver src/lib/leads.ts).
model Lead {
  id                 String   @id @default(cuid())
  nome               String
  empresa            String?
  cnpjCpf            String?  // como recebido (formatado)
  cnpjCpfNorm        String?  // só dígitos (11/14) — chave de dedup
  contato            String?  // telefone/whatsapp como recebido
  contatoNorm        String?  // últimos 11 dígitos — chave de dedup
  email              String?
  emailNorm          String?  // minúsculo — chave de dedup
  origem             String?  // ex.: "chat-atendimento"
  externalId         String?  @unique // id do lead no sistema externo — dedup forte
  valorEstimadoCents Int      @default(0)
  observacoes        String?
  stage              String   @default("novo") // ver LEAD_STAGES
  order              Int      @default(0)
  ixcClienteId       String?  // casado a um cliente IXC (por doc), se houver
  assignedUserId     String?  // responsável OpenBoard
  payload            Json?    // payload bruto do ingest (auditoria)
  lastContactAt      DateTime @default(now()) // último toque (ingest re-bate aqui)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Análise IA da conversa do atendente (sob demanda; re-executável, sobrescreve).
  analiseNota           Int?      // 0-10
  analiseResumo         String?
  analisePontos         Json?     // { fortes:[], aMelhorar:[], proximoPasso:"" }
  analiseModelo         String?
  analiseTokensIn       Int?
  analiseTokensOut      Int?
  analiseCustoUsdMicros Int?      // custo em USD * 1_000_000 (inteiro)
  analiseAt             DateTime?

  @@index([stage])
  @@index([cnpjCpfNorm])
  @@index([contatoNorm])
  @@index([emailNorm])
}

// Mensagens da conversa do AtendAI, por lead. Acumulam entre re-entradas de fila;
// dedup por externalId (id da mensagem no AtendAI). Ver src/server/comercial/leads.ts.
model LeadMensagem {
  id          String    @id @default(cuid())
  leadId      String    // loose FK -> Lead.id (sem constraint, padrão do comercial)
  externalId  String    @unique // mensagensAtendimento[].id no AtendAI
  remetente   String?   // "OpenSuite" / nome do atendente / cliente
  mensagem    String
  tipo        String?   // tipo_mensagem (text/...)
  mensagemBot Boolean   @default(false) // mensagem_bot || mensagem_ia
  sentAt      DateTime? // data_envio
  createdAt   DateTime  @default(now())

  @@index([leadId])
}

// Log de cada execução de sync (observabilidade — ver handoff §9).
model SyncRun {
  id         String    @id @default(cuid())
  kind       String // "full" | "vendedores" | "contratos" | "reconcile"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  durationMs Int?
  processed  Int       @default(0)
  errors     Int       @default(0)
  fatalError String?

  @@index([kind, startedAt])
}

// Meta do time por mês (replica SalesTracker §4). Global.
model Meta {
  id            String   @id @default(cuid())
  mes           Int
  ano           Int
  metaContratos Int      @default(0) // meta de contratos ativos no mês
  metaMrrCents  Int      @default(0) // meta de MRR no mês (opcional)
  metaSemanal   Int      @default(0) // meta semanal de contratos (opcional)
  createdAt     DateTime @default(now())

  @@unique([mes, ano])
}

// Meta por vendedor por mês (vínculo frouxo por vendedorIxcId, sem FK).
model MetaVendedor {
  id            String   @id @default(cuid())
  vendedorIxcId String
  mes           Int
  ano           Int
  metaContratos Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([vendedorIxcId, mes, ano])
  @@index([mes, ano])
}

// Apontamento diário manual de esforço comercial (replica SalesTracker §6).
// 1 linha por vendedor+dia. NÃO vem do IXC — preenchido na tela.
model RelatorioDiario {
  id            String   @id @default(cuid())
  vendedorIxcId String
  data          DateTime // dia (00:00 UTC)
  leads         Int      @default(0)
  contatos      Int      @default(0)
  callsReunioes Int      @default(0)
  vendas        Int      @default(0)
  valorCents    Int      @default(0)
  produtos      Json?    // [{ nome: string, valorCents: number }] — vendas do dia
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([vendedorIxcId, data])
  @@index([data])
}
