# Copie para .env e ajuste. Gere AUTH_SECRET com: openssl rand -base64 48
# AUTH_SECRET é OBRIGATÓRIO e precisa de no mínimo 32 caracteres — sem isso o app
# nem sobe (falha-fechado). Nunca reutilize o placeholder em produção.
DATABASE_URL="postgresql://openboard:openboard@localhost:5432/openboard?schema=public"
AUTH_SECRET="gere-com-openssl-rand-base64-48-no-minimo-32-chars"

# ── Marketing / Instagram ────────────────────────────────────────────────────
# Chave AES p/ criptografar o access token do Instagram em repouso (32 bytes base64).
# Gere com: openssl rand -base64 32. Sem ela, conectar/renovar token do IG falha.
TOKEN_ENC_KEY=

# ── Comercial / Integração IXCSoft ──────────────────────────────────────────
# Em Next tudo aqui é server-only (sem prefixo NEXT_PUBLIC) → token nunca vai pro
# bundle do frontend. Ver IXC_INTEGRATION_HANDOFF.md.
IXC_BASE_URL="https://central.openitgroup.com.br"
# Proxy que injeta Authorization + header `ixcsoft: listar`. Rota: {proxy}/ixc/{tabela}
IXC_PROXY_URL="http://104.234.186.129:3001"
# SEGREDO — base64 de "usuario:token_webservice", já com o prefixo "Basic ".
# Valor real está no .env.local do projeto SalesTracker — copiar de lá.
IXC_TOKEN="Basic <COLAR_TOKEN_REAL_AQUI>"
# (Opcional) nome do campo de status no JSON do contrato, se divergir do default.
# IXC_CAMPO_STATUS_CONTRATO="status"
# Filiais permitidas (CSV). Resto é descartado no sync.
IXC_FILIAIS="1,2,6"

# Webhook de ingest de leads (chat de atendimento -> POST /api/comercial/leads)
LEADS_INGEST_TOKEN=

# ── Análise IA da conversa (OpenAI / GPT) — server-only ──────────────────────
# Chave secreta da OpenAI (nunca no bundle/chat/git). Sem ela, o botão de análise fica off.
OPENAI_API_KEY=
# Modelo e preço por 1M tokens (USD). Muda com frequência na OpenAI → ajustar aqui.
OPENAI_MODEL=gpt-4o-mini
OPENAI_PRICE_IN_PER_1M=0.15
OPENAI_PRICE_OUT_PER_1M=0.60

# ── Marketing / Links & QR (encurtador) ──────────────────────────────────────
# Base da URL curta impressa no QR (prod com basePath: http://104.234.186.129/openboard).
# Sem definir, cai em APP_URL e depois no host da request (ok em dev).
# ATENÇÃO: QR impresso com IP quebra se o IP mudar — aponte um domínio antes de
# mandar material pra gráfica.
# SHORT_BASE_URL=
# Sal do hash de IP dos cliques (LGPD — IP puro nunca é gravado). openssl rand -hex 16
SHORT_IP_SALT=
# Geolocalização local MaxMind GeoLite2 (sem limite de requisições). Conta gratuita
# em maxmind.com → Manage License Keys → gerar chave; depois: npm run geoip:update
# Sem o arquivo .mmdb, cai no fallback ip-api.com (~45 req/min).
MAXMIND_LICENSE_KEY=
# GEOIP_DB_PATH=geoip/GeoLite2-City.mmdb

# ── Esqueci minha senha ───────────────────────────────────────────────────────
# Base do link de redefinição (prod com basePath: http://104.234.186.129/openboard).
# Sem definir, usa o host da request (ok em dev).
# APP_URL=
# E-mail via Resend (opcional). Sem configurar, o link sai no LOG do servidor.
# RESEND_API_KEY=
# RESET_EMAIL_FROM="OpenBoard <naoresponda@seudominio.com>"
